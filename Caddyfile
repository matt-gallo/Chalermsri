{
	admin off
	persist_config off
	auto_https off
}

:{$PORT:8080} {
	root * /srv
	encode zstd gzip
	file_server

	@nocache {
		path *.html *.css *.js
	}
	header @nocache Cache-Control "no-cache, must-revalidate"

	@media {
		path *.svg *.png *.jpg *.jpeg *.webp *.woff2 *.mp4 *.webm *.ico
	}
	header @media Cache-Control "public, max-age=604800, immutable"

	header {
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "geolocation=(), microphone=(), camera=()"
		-Server
	}

	try_files {path} {path}/ /index.html
}
